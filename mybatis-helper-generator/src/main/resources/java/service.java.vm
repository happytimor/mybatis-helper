package ${packageName}.${service};

import ${packageName}.domain.entity.convertor.${ClassName}Convertor;
import ${packageName}.mapper.${ClassName}Mapper;
import ${packageName}.domain.entity.${ClassName};
import ${packageName}.domain.vo.request.${ClassName}AddReq;
import ${packageName}.domain.vo.request.${ClassName}EditReq;
import ${packageName}.domain.vo.request.${ClassName}QueryReq;
import ${packageName}.domain.vo.response.${ClassName}Resp;
import io.github.happytimor.mybatis.helper.core.metadata.Page;
import io.github.happytimor.mybatis.helper.core.service.BaseService;
import io.github.happytimor.mybatis.helper.core.wrapper.SelectWrapper;
import io.github.happytimor.mybatis.helper.core.wrapper.UpdateWrapper;
import org.apache.commons.lang3.StringUtils;
import org.springframework.stereotype.Service;

import java.util.List;

/**
 * ${ClassName}Service
 * 
 * @author ${author}
 */
@Service
public class ${ClassName}Service extends BaseService<${ClassName}Mapper, ${ClassName}> {

    /**
     * 列表
     * 
     * @param ${className}QueryReq 查询请求类
     * @return Page<${ClassName}Resp> 分页数据
     */
    public Page<${ClassName}Resp> queryPage(${ClassName}QueryReq ${className}QueryReq) {
        int pageNo = ${className}QueryReq.getPageNo();
        int pageSize = ${className}QueryReq.getPageSize();
        Page<${ClassName}> page = this.selectPage(pageNo, pageSize, new SelectWrapper<${ClassName}>()
#foreach ($column in $columns)
#if(!$table.isSuperColumn($column.javaField) && $column.javaType == 'String')
                .likeNotBlank(${ClassName}::get${column.capJavaField}, StringUtils.trim(${className}QueryReq.get${column.capJavaField}()))
#end
#end
                .orderByDesc(${ClassName}::get${pkColumn.capJavaField})
        );
        List<${ClassName}> records = page.getRecords();
        List<${ClassName}Resp> voList = ${ClassName}Convertor.INSTANCE.mapTo${ClassName}RespList(records);
        Page<${ClassName}Resp> pageVo = new Page<>();
        pageVo.setPageNo(page.getPageNo());
        pageVo.setPageSize(page.getPageSize());
        pageVo.setTotal(page.getTotal());
        pageVo.setRecords(voList);
        return pageVo;
    }

    /**
     * 新增
     *
     * @param ${className}AddReq 新增请求类
     */
    public void add${ClassName}(${ClassName}AddReq ${className}AddReq) {
        ${ClassName} ${className} = ${ClassName}Convertor.INSTANCE.mapTo${ClassName}(${className}AddReq);
        this.insert(${className});
    }

    /**
     * 修改
     *
     * @param ${className}EditReq 编辑请求类
     * @return Boolean 是否更新成功
     */
    public Boolean edit${ClassName}(${ClassName}EditReq ${className}EditReq) {
        return this.update(new UpdateWrapper<${ClassName}>()
#foreach ($column in $columns)
#if(!$table.isSuperColumn($column.javaField) && !$column.isPk() && $column.javaField != "gmtCreated")
                .set(${ClassName}::get${column.capJavaField}, ${className}EditReq.get${column.capJavaField}())
#end
#end
                .eq(${ClassName}::get${pkColumn.capJavaField}, ${className}EditReq.get${pkColumn.capJavaField}())
        ) > 0;
    }

    /**
     * 删除
     * 
     * @param ${pkColumn.javaField} 主键id
     */
    public void delete${ClassName}(${pkColumn.javaType} ${pkColumn.javaField}) {
        this.deleteById(${pkColumn.javaField});
    }
}
